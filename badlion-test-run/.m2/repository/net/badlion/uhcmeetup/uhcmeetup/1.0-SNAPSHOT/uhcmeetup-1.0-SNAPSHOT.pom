<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>net.badlion.uhcmeetup</groupId>
  <artifactId>uhcmeetup</artifactId>
  <name>UHCMeetup</name>
  <version>1.0-SNAPSHOT</version>
  <build>
    <sourceDirectory>${basedir}/src/main/java</sourceDirectory>
    <defaultGoal>clean install</defaultGoal>
    <resources>
      <resource>
        <targetPath>.</targetPath>
        <filtering>true</filtering>
        <directory>${basedir}/src/main/resources/</directory>
        <includes>
          <include>*.yml</include>
        </includes>
      </resource>
    </resources>
    <finalName>badlionuhcmeetup</finalName>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>2.3.2</version>
        <configuration>
          <source>1.7</source>
          <target>1.7</target>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>2.3</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <artifactSet>
                <includes>
                  <include>net.badlion.arenacommon:arenacommon</include>
                </includes>
                <excludes>
                  <exclude>org.bukkit:*</exclude>
                  <exclude>io.nv.bukkit:*</exclude>
                  <exclude>net.badlion.common:*</exclude>
                  <exclude>net.badlion.gberry:*</exclude>
                  <exclude>net.badlion.gguard:*</exclude>
                  <exclude>net.badlion.gpermissions:*</exclude>
                  <exclude>net.badlion.ministats:*</exclude>
                  <exclude>net.badlion.mpg:*</exclude>
                  <exclude>net.badlion.worldrotator:*</exclude>
                  <exclude>net.badlion.smellymapvotes:*</exclude>
                  <exclude>net.badlion.disguise:*</exclude>
                  <exclude>net.badlion.cosmetics:*</exclude>
                  <exclude>net.badlion.combattag:*</exclude>
                  <exclude>net.badlion.worldborder:*</exclude>
                </excludes>
              </artifactSet>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <dependencies>
    <dependency>
      <groupId>org.bukkit</groupId>
      <artifactId>bukkit</artifactId>
      <version>1.8.8-R0.1-SNAPSHOT</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>joda-time</groupId>
      <artifactId>joda-time</artifactId>
      <version>2.7</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.gberry</groupId>
      <artifactId>gberry</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.gguard</groupId>
      <artifactId>gguard</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.common</groupId>
      <artifactId>common</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.mpg</groupId>
      <artifactId>mpg</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <artifactId>cleanroomgenerator</artifactId>
          <groupId>io.nv.bukkit</groupId>
        </exclusion>
        <exclusion>
          <artifactId>gpermissions</artifactId>
          <groupId>net.badlion.gpermissions</groupId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>net.badlion.worldrotator</groupId>
      <artifactId>worldrotator</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.ministats</groupId>
      <artifactId>ministats</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <artifactId>cleanroomgenerator</artifactId>
          <groupId>io.nv.bukkit</groupId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>net.badlion.disguise</groupId>
      <artifactId>disguise</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.cosmetics</groupId>
      <artifactId>cosmetics</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.combattag</groupId>
      <artifactId>combattag</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>net.badlion.worldborder</groupId>
      <artifactId>worldborder</artifactId>
      <version>1.0-SNAPSHOT</version>
      <scope>compile</scope>
    </dependency>
  </dependencies>
  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>

